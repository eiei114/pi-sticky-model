{
  "name": "pi-sticky-model",
  "version": "0.2.1",
  "description": "Pi extension that keeps your selected model across /new, /resume, and /fork within the same session. Model resets on Ctrl+C.",
  "type": "module",
  "license": "MIT",
  "author": "Keisu",
  "keywords": [
    "pi-package",
    "pi",
    "extension",
    "model",
    "session",
    "sticky",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eiei114/pi-sticky-model.git"
  },
  "bugs": {
    "url": "https://github.com/eiei114/pi-sticky-model/issues"
  },
  "homepage": "https://github.com/eiei114/pi-sticky-model#readme",
  "files": [
    "extensions/",
    "lib/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "ci": "npm run typecheck && npm test && npm run pack:check",
    "pack:check": "npm pack --dry-run"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "latest",
    "@earendil-works/pi-coding-agent": "latest",
    "@earendil-works/pi-tui": "latest",
    "typebox": "latest",
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3"
  }
}
